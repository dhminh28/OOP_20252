# PostgreSQL managed outside Docker, for example through pgAdmin4
# Docker connects to the host PostgreSQL server through host.docker.internal.
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=ITSS_Nhat
DB_USERNAME=postgres
DB_PASSWORD=change-me
FLYWAY_ENABLED=true
JPA_DDL_AUTO=validate
JWT_SECRET=change-this-local-secret-with-at-least-32-chars
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGIN=http://localhost:5173
MAIL_FROM=no-reply@cospace.local
# Optional SMTP settings for real email delivery
# SPRING_MAIL_HOST=smtp.example.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-smtp-user
# SPRING_MAIL_PASSWORD=your-smtp-password
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Frontend
VITE_API_URL=http://localhost:8080/api

# When running the backend directly with Maven instead of Docker, export:
# DB_URL=jdbc:postgresql://localhost:5432/ITSS_Nhat
