<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coworking.controller.DashboardController">
    <left>
        <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #2e3440;">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" text="Navigation" />
                <Button maxWidth="1.7976931348623157E308" text="Dashboard" onAction="#showDashboard" />
                <Button maxWidth="1.7976931348623157E308" text="Workspaces" />
                <Button maxWidth="1.7976931348623157E308" text="Bookings" onAction="#showBookings" />
                <Button maxWidth="1.7976931348623157E308" text="Customers" />
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="mainContent">
            <children>
                <VBox spacing="12.0">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                    <children>
                        <TextField fx:id="searchField" promptText="Search workspaces..." />
                        <FlowPane fx:id="workspaceFlowPane" hgap="12.0" vgap="12.0" style="-fx-background-color: #eceff4;" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="16.0" left="0.0" right="0.0" top="0.0" />
                            </padding>
                        </FlowPane>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
