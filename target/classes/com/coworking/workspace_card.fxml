<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="10.0" styleClass="card" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coworking.controller.WorkspaceCardController">
    <padding>
        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
    </padding>
    <children>
        <ImageView fx:id="typeIconImageView" fitHeight="56.0" fitWidth="56.0" pickOnBounds="true" preserveRatio="true" />
        <Label fx:id="nameLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Workspace Name" />
        <Label fx:id="priceLabel" style="-fx-font-size: 14px;" text="0.00 / hour" />
        <Button fx:id="bookNowButton" text="Book Now" />
    </children>
</VBox>
